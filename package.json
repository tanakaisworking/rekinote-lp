{
  "name": "app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3002",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "smoke": "bash ./scripts/smoke-check.sh",
    "smoke:prod": "bash ./scripts/smoke-check.sh https://rekinote.app",
    "deploy:pages": "npm run build && wrangler pages deploy out --project-name rekinote-lp --branch main --commit-dirty=true",
    "deploy:pages:fresh": "npm run build && wrangler pages deploy out --project-name rekinote-lp --branch main --commit-dirty=true --skip-caching"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "next": "14.2.35",
    "react": "^18",
    "react-dom": "^18"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
