---
import type { DictHero } from "../../i18n/types";
import { HeroStreamCanvas } from "../react/HeroStreamCanvas";
import { HeroDownloadDropdown } from "../react/HeroDownloadDropdown";

interface Props {
  dict: DictHero;
  lang: "ja" | "en";
  audience?: "business" | "student" | "developer";
}

const { dict, lang, audience = "business" } = Astro.props;
---

<section class="relative overflow-x-clip">
  <div class="hero-canvas-wrap">
    <HeroStreamCanvas lang={lang} audience={audience} client:visible />
  </div>
  <div class="hero-orb" />
  <div class="absolute left-1/2 -translate-x-1/2 top-[480px] w-[1200px] h-[420px] pointer-events-none opacity-60"
       style="background: radial-gradient(ellipse 60% 50% at 50% 50%, rgba(139,92,246,0.10), transparent 70%)" />
  <div class="container-x relative z-10 px-6 pt-20 pb-12 md:pt-28 md:pb-20 grid md:grid-cols-2 gap-12 items-center">
    <div class="max-w-[640px] text-center md:text-left">
      <h1 class="text-4xl md:text-[60px] font-bold tracking-tight leading-[1.15]">
        {dict.title1}<br />
        <span class="gradient-text">{dict.title2}</span>
      </h1>
      <p class="mt-7 text-lg md:text-[20px] text-[#ececef]/95 leading-[1.7] max-w-[560px] mx-auto md:mx-0">{dict.subtitle}</p>

      <div class="relative mt-12 mb-10 md:hidden flex justify-center overflow-visible">
        <div class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 pointer-events-none"
             style="width: 200vw; height: 200vw; background: radial-gradient(circle at 50% 50%, rgba(139,92,246,0.25), transparent 65%)" />
        <div class="flex items-center justify-center p-4 relative">
          <img
            src="/logo-transparent.png"
            alt="Reki note"
            width="600"
            height="600"
            loading="eager"
            class="hero-logo-target w-full h-auto max-w-[280px] drop-shadow-[0_0_60px_rgba(139,92,246,0.5)] select-none pointer-events-none"
            draggable="false"
          />
          <div class="absolute inset-0 z-10 bg-transparent" />
        </div>
      </div>

      <p class="mt-5 muted text-[15px] max-w-[560px] mx-auto md:mx-0 leading-[1.85]">{dict.desc}</p>
      <div class="mt-9 flex justify-center md:justify-start">
        <HeroDownloadDropdown lang={lang} label={lang === "en" ? "Free Download" : "無料ダウンロード"} client:load />
      </div>
    </div>

    <div class="relative hidden md:block">
      <div class="absolute -inset-12 pointer-events-none"
           style="background: radial-gradient(circle at 50% 50%, rgba(139,92,246,0.25), transparent 70%)" />
      <div class="flex items-center justify-center p-8 relative">
        <img
          src="/logo-transparent.png"
          alt="Reki note"
          width="600"
          height="600"
          loading="eager"
          class="hero-logo-target w-full h-auto max-w-[320px] drop-shadow-[0_0_60px_rgba(139,92,246,0.5)] select-none pointer-events-none"
          draggable="false"
        />
        <div class="absolute inset-0 z-10 bg-transparent" />
      </div>
    </div>
  </div>
</section>

<style is:global>
  .hero-canvas-wrap,
  .hero-canvas-wrap > astro-island {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
  }
</style>
