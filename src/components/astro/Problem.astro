---
import type { DictProblem } from "../../i18n/types";

interface Props {
  dict: DictProblem;
}

const { dict } = Astro.props;
const divider = dict.titleDivider ?? "、";
---

<section class="section" id="problem">
  <div class="container-x">
    <div class="max-w-[760px]">
      <span class="eyebrow">{dict.eyebrow}</span>
      <h2 class="mt-4 text-3xl md:text-[42px] font-bold tracking-tight leading-tight">
        {dict.title1}
        <span class="md:hidden">{divider}<br /></span>
        <span class="hidden md:inline">{divider}</span>
        <span class="gradient-text">{dict.title2}</span>
        {dict.title3}
      </h2>
      <p class="mt-6 muted leading-[1.95]">{dict.desc}</p>
    </div>

    <div class="mt-14 grid md:grid-cols-2 gap-5">
      <div class="card p-8 md:p-10 flex flex-col">
        <div class="text-xs font-mono-num tracking-widest uppercase text-[#5e5e6a]">{dict.before}</div>
        <h3 class="mt-3 text-xl font-semibold">{dict.beforeTitle}</h3>
        <ul class="mt-7 space-y-0 flex-1">
          {dict.beforeItems.map((it, index) => (
            <li
              class={`flex flex-col gap-1 sm:flex-row sm:items-center sm:justify-between text-[14.5px] py-3 ${
                index === dict.beforeItems.length - 1 ? "" : "border-b border-line"
              }`}
            >
              <span class="text-[#ececef]/90">{it.name}</span>
              <span class="font-mono-num muted text-[13px] sm:text-[14.5px]">{it.price}</span>
            </li>
          ))}
        </ul>
        <div class="mt-8 pt-6 border-t border-line-strong flex flex-col gap-2 sm:flex-row sm:items-baseline sm:justify-between sm:gap-3">
          <span class="font-semibold">{dict.total}</span>
          <div class="sm:text-right">
            <span class="font-mono-num text-2xl text-[#ececef]">{dict.beforeTotal}</span>
            <div class="mt-1 text-[12px] dim">{dict.beforeTotalDesc}</div>
          </div>
        </div>
      </div>

      <div class="card-strong p-8 md:p-10 relative overflow-hidden flex flex-col">
        <div class="absolute inset-0 pointer-events-none bg-[radial-gradient(circle_at_85%_0%,rgba(139,92,246,0.08),transparent_55%)]" />
        <div class="relative flex-1">
          <div class="text-xs font-mono-num tracking-widest uppercase text-[#a78bfa]">{dict.after}</div>
          <h3 class="mt-3 text-xl font-semibold">{dict.afterTitle}</h3>
          <div class="mt-7 flex items-center gap-3">
            <img src="/logo.png" alt="" width="32" height="32" class="rounded-md" />
            <span class="font-semibold text-lg">Reki note</span>
          </div>
          <p class="mt-3 text-[14.5px] muted">{dict.afterDesc}</p>
          <ul class="mt-8 space-y-3 text-[14.5px]">
            {dict.afterItems.map((item) => (
              <li class="flex gap-3"><span class="text-[#a78bfa]">✓</span><span>{item}</span></li>
            ))}
          </ul>
        </div>
        <div class="relative mt-8 pt-6 border-t border-line-strong flex flex-col gap-2 sm:flex-row sm:items-baseline sm:justify-between sm:gap-3">
          <span class="font-semibold">{dict.total}</span>
          <div class="sm:text-right">
            <span class="font-mono-num text-2xl gradient-text font-bold">{dict.afterTotal}</span>
            <div class="mt-1 text-[12px] dim">{dict.afterTotalDesc}</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
