---
import type { DictCompare } from "../../i18n/types";

interface Props {
  dict: DictCompare;
}

const { dict } = Astro.props;

const palette = {
  good: {
    icon: `<path d="M4 12.5l5.5 5.5L20 6" stroke="#059669" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>`,
  },
  soso: {
    icon: `<polygon points="12,2 23.5,21.5 0.5,21.5" stroke="#d97706" stroke-width="2.5" fill="none" stroke-linejoin="round"/><line x1="12" y1="9.5" x2="12" y2="14.5" stroke="#d97706" stroke-width="2.8" stroke-linecap="round"/><circle cx="12" cy="18" r="1.5" fill="#d97706"/>`,
  },
  bad: {
    icon: `<path d="M5 5l14 14M19 5L5 19" stroke="#e11d48" stroke-width="3.5" stroke-linecap="round"/>`,
  },
} as const;
---

<section class="section" id="compare">
  <div class="container-x">
    <div class="mb-10">
      <span class="eyebrow">{dict.eyebrow}</span>
      <h2 class="mt-4 text-3xl md:text-[42px] font-bold tracking-tight leading-tight">
        {dict.title1}<span class="gradient-text">{dict.title2}</span>
      </h2>
      <p class="mt-4 muted leading-[1.95]">{dict.desc}</p>
    </div>

    <div class="compare-card relative overflow-x-auto">
      <table class="compare relative min-w-[760px]">
        <colgroup>
          <col style="width: 26%" />
          <col style="width: 24.6667%" />
          <col style="width: 24.6667%" />
          <col style="width: 24.6667%" />
        </colgroup>
        <thead>
          <tr>
            <th class="w-[26%]">{dict.colFeature}</th>
            <th class="highlight highlight-top">
              <span class="inline-flex items-center gap-2">
                <span class="w-1.5 h-1.5 rounded-full bg-[#a78bfa]" />
                Reki note
              </span>
            </th>
            <th>{dict.col2}</th>
            <th>{dict.col3}</th>
          </tr>
        </thead>
        <tbody>
          {dict.rows.map((r, index) => {
            const rekiP = palette[r.reki.tone];
            const otherP = palette[r.otherAi.tone];
            const notesP = palette[r.notes.tone];
            return (
              <tr>
                <td class="muted">{r.feature}</td>
                <td class={index === dict.rows.length - 1 ? "highlight highlight-bottom" : "highlight"}>
                  <div class="compare-cell">
                    <span class="compare-tone" aria-hidden="true">
                      <svg viewBox="0 0 24 24" class="h-4 w-4" set:html={rekiP.icon} />
                    </span>
                    <span class="compare-copy compare-copy--emphasized">{r.reki.text}</span>
                  </div>
                </td>
                <td>
                  <div class="compare-cell">
                    <span class="compare-tone" aria-hidden="true">
                      <svg viewBox="0 0 24 24" class="h-4 w-4" set:html={otherP.icon} />
                    </span>
                    <span class="compare-copy">{r.otherAi.text}</span>
                  </div>
                </td>
                <td>
                  <div class="compare-cell">
                    <span class="compare-tone" aria-hidden="true">
                      <svg viewBox="0 0 24 24" class="h-4 w-4" set:html={notesP.icon} />
                    </span>
                    <span class="compare-copy">{r.notes.text}</span>
                  </div>
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
    <p class="mt-5 dim text-xs">{dict.footnote}</p>
  </div>
</section>
