---
import type { DictFooter } from "../../i18n/types";
import { LanguageSelect } from "../react/LanguageSelect";

interface Props {
  dict: DictFooter;
  lang: "ja" | "en";
  audience: "business" | "student" | "developer" | "vision";
  pathname: string;
}

const { dict, lang, audience, pathname } = Astro.props;

const links = [
  { key: "business", href: `/${lang}/lp/business/`, label: dict.businessLabel, desc: dict.businessDesc },
  { key: "student", href: `/${lang}/lp/student/`, label: dict.studentLabel, desc: dict.studentDesc },
  { key: "developer", href: `/${lang}/lp/developer/`, label: dict.developerLabel, desc: dict.developerDesc },
  ...(dict.visionLabel ? [{ key: "vision" as const, href: `/${lang}/product/vision/`, label: dict.visionLabel, desc: dict.visionDesc ?? "" }] : []),
  { key: "other", href: `/${lang}/lp/`, label: dict.otherLabel, desc: dict.otherDesc },
];
---

<footer class="border-t border-line">
  <div class="container-x px-6 py-14">
    <div class="text-xs font-mono-num tracking-[0.22em] uppercase text-[#8e8e98]">{dict.switchHeading}</div>
    <div class="mt-4 grid gap-3 grid-cols-2 lg:grid-cols-4">
      {links.map((link) => {
        const isActive = link.key === audience;
        return (
          <a
            href={link.href}
            class={`rounded-2xl border p-4 transition-colors duration-180 ${
              isActive
                ? "border-[rgba(167,139,250,0.55)] bg-[rgba(139,92,246,0.08)]"
                : "border-line bg-[rgba(18,18,24,0.55)] hover:border-line-strong"
            }`}
          >
            <div class="flex items-center justify-between gap-2">
              <span class="text-sm font-semibold text-[#ececef]">{link.label}</span>
              {isActive && <span class="text-xs text-[#cdbdff] shrink-0">{dict.currentLabel}</span>}
            </div>
            <p class="mt-2 text-xs leading-6 text-[#9d9daa]">{link.desc}</p>
          </a>
        );
      })}
    </div>
  </div>

  <div class="border-t border-line">
    <div class="container-x px-6 py-6 flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
      <div class="flex items-center gap-2.5">
        <img src="/logo.png" alt="" width="20" height="20" class="rounded-md" />
        <span class="text-sm font-semibold tracking-tight">{dict.tagline}</span>
      </div>
      <div class="flex flex-wrap items-center gap-4 text-xs muted">
        <LanguageSelect lang={lang} pathname={pathname} client:load />
        <span class="w-px h-3.5 bg-[rgba(255,255,255,0.12)]" aria-hidden />
        <a href="https://hibachi-inc.jp" class="hover:text-[#ececef] transition-colors duration-180">{dict.company}</a>
        <span class="w-px h-3.5 bg-[rgba(255,255,255,0.12)]" aria-hidden />
        <a href={`/${lang}/legal/privacy/`} class="hover:text-[#ececef] transition-colors duration-180">{lang === "ja" ? "プライバシーポリシー" : "Privacy Policy"}</a>
        <span class="w-px h-3.5 bg-[rgba(255,255,255,0.12)]" aria-hidden />
        <a href={`/${lang}/legal/terms/`} class="hover:text-[#ececef] transition-colors duration-180">{lang === "ja" ? "利用規約" : "Terms of Service"}</a>
        {lang === "ja" && (
          <>
            <span class="w-px h-3.5 bg-[rgba(255,255,255,0.12)]" aria-hidden />
            <a href="/ja/legal/tokushoho/" class="hover:text-[#ececef] transition-colors duration-180">特定商取引法に基づく表記</a>
          </>
        )}
        <span class="w-px h-3.5 bg-[rgba(255,255,255,0.12)]" aria-hidden />
        <span class="dim">© 2026 HIBACHI inc.</span>
      </div>
    </div>
  </div>
</footer>
