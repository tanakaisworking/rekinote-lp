    margin: 0;
    list-style: none;
  }

  .team-hero-panel-grid li {
    margin-top: 8px;
    color: #c8d0dc;
    font-size: 12px;
  }

  .team-hero-table {
    margin-top: 12px;
    padding: 6px 0;
  }

  .team-hero-table div {
    display: grid;
    grid-template-columns: 52px 1fr auto;
    gap: 10px;
    align-items: center;
    padding: 9px 12px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.07);
