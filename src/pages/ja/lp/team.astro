---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { TeamPlanApplicationForm } from "../../../components/react/TeamPlanApplicationForm";

const pipeline = [
  { title: "Capture", label: "録る", body: "Zoom / Meet / Teams / Slack / 対面まで。会議ツールをまたいで会話を取り込む。" },
  { title: "Local", label: "起こす", body: "PC上で文字起こし。秘密度の高い会話はローカル運用を選べる。" },
  { title: "Summary", label: "要約", body: "全文ではなく、共有に必要な要約・決定事項・メタデータに変換。" },
  { title: "Dashboard", label: "見る", body: "部門別の進捗、関心ごと、アクションを組織で可視化。" },
  { title: "AI", label: "つなぐ", body: "社内会話を検索・分析・生成AI活用に接続できる状態へ。" },
];

const supportedTools = ["Google Meet", "Zoom", "Microsoft Teams", "Slack", "対面会議", "1on1"];

const features = [
  {
    title: "全ツール対応",
    body: "Google Meet、Zoom、Teams、Slack、対面会議まで。会議ツールごとのAI契約ではなく、PC上の会話をまとめて扱います。",
    points: ["Bot招待不要", "会議ツールをまたいで記録", "対面・1on1にも対応"],
  },
  {
    title: "会話を業務データ化",
    body: "議事録を溜めるだけでなく、決定事項、論点、関心ごと、アクションを組織で検索・共有できる形にします。",
    points: ["進捗率を可視化", "アクションを一覧管理", "部門・トピック別に集計"],
  },
  {
    title: "監視ではなく要約共有",
    body: "社員の一言一句を監視するのではなく、業務に必要な要約・議事録・タスクを提出する設計です。",
    points: ["個人原本と組織提出を分離", "1on1ポリシーに対応", "心理的安全性を守る"],
  },
];

const meetings = [
  { date: "5/31", app: "Teams", title: "週次プロダクト会議", dept: "開発", topic: "リリース計画", actions: "5 / 7", privacy: "マスキング済み" },
  { date: "5/30", app: "Meet", title: "営業戦略MTG", dept: "営業", topic: "商談優先度", actions: "3 / 6", privacy: "マスキング済み" },
  { date: "5/30", app: "Slack", title: "顧客オンボーディング改善", dept: "CS", topic: "定着支援", actions: "4 / 5", privacy: "マスキング済み" },
  { date: "5/29", app: "1on1", title: "キャリアレビュー", dept: "人事", topic: "人材育成", actions: "-", privacy: "1on1保護" },
];

const functionBlocks = [
  {
    title: "組織ダッシュボード",
    body: "会話量、未完了アクション、関心ごとの推移を部署別に確認。報告を待たずに、組織の状態を把握できます。",
    items: ["会話量・進捗率", "部署別トピック", "アクション完了率"],
  },
  {
    title: "会話タイムライン",
    body: "会議・通話・1on1を時系列で整理。誰が参加し、何が決まり、次に何をするかを追えます。",
    items: ["会議メタデータ", "要約と出典", "参加者ベース共有"],
  },
  {
    title: "セキュリティ設定",
    body: "ローカル運用、クラウド提出、NDA、監査ログ、アクセス権限を導入ポリシーに合わせて設計します。",
    items: ["ローカル/クラウド境界", "監査ログ", "権限・提出範囲"],
  },
];

const localItems = [
  "録音・文字起こしをPCローカルに保持",
  "必要な会議だけユーザー操作で提出",
  "秘密度の高い会話はクラウドに送らない運用が可能",
];

const cloudItems = [
  "提出された要約・議事録・メタデータを組織で検索",
  "アクション項目、期限、担当者をチームで管理",
  "NDA締結、権限管理、監査ログを契約・運用で担保",
];

const useCases = [
  { team: "営業", title: "商談の温度感と宿題を残す", body: "顧客との会話から、検討理由、懸念、次回アクションをチームで共有。" },
  { team: "CS", title: "顧客の困りごとを横断で見る", body: "オンボーディングや定例会の会話を集約し、解約リスクや要望を早く拾う。" },
  { team: "人事・1on1", title: "守る会話と共有する情報を分ける", body: "センシティブな原本は守り、組織に必要なアクションだけ扱う。" },
  { team: "経営会議", title: "決定理由を後から追える", body: "なぜ決めたか、何が未決か、誰が次に動くかを会話から残す。" },
];

const faqs = [
  {
    q: "音声データはクラウドに送られますか？",
    a: "ローカル運用では、録音・文字起こし・要約をPC内に残す設計が可能です。チームクラウド機能を使う場合は、提出された要約・議事録・メタデータを組織で扱います。",
  },
  {
    q: "ローカル運用とチームクラウド運用の違いは？",
    a: "ローカル運用は個人PC内で完結する使い方です。チームクラウド運用は、組織で検索・共有・レポート化するために、提出範囲を決めてクラウド側で扱います。",
  },
  {
    q: "社員の会話をすべて監視するツールですか？",
    a: "いいえ。Reki note Teamは全文監視ではなく、業務に必要な要約・議事録・アクションを共有する設計です。1on1や人事面談などは提出しないポリシーも設計できます。",
  },
  {
    q: "NDAは締結できますか？",
    a: "はい。チームプラン契約時に秘密保持契約を締結し、クラウド機能利用時のデータ取り扱いを契約と運用ポリシーで明確にします。",
  },
  {
    q: "Google MeetやZoom以外でも使えますか？",
    a: "PC上の音声を扱うため、Google Meet、Zoom、Teams、Slack、対面会議など、特定の会議プラットフォームに依存しない運用が可能です。",
  },
  {
    q: "料金は席課金ですか？",
    a: "Teamは ¥5,000 / 席 / 月 を基準にしています。Enterpriseは専用環境や個別要件に応じて、初期1,000万円〜で個別見積もりです。",
  },
];
---

<BaseLayout
  title="Reki note Team — 会話から、業務の進捗が見える。"
  description="Reki note Teamは、会議・通話・1on1を要約し、決定事項・関心ごと・アクションを組織で扱えるデータに変換するチーム向けサービスです。"
  lang="ja"
  canonical="https://rekinote.app/ja/lp/team/"
  singleLang
>
  <main class="team-page">
    <header class="team-header">
      <a href="/ja/lp/" class="team-logo" aria-label="Reki note">
        <img src="/logo.png" alt="" width="28" height="28" />
        <span>Reki note</span>
        <strong>Team</strong>
      </a>
      <nav aria-label="ページ内ナビゲーション">
        <a href="#features">特長</a>
        <a href="#product">機能</a>
        <a href="#security">セキュリティ</a>
        <a href="#pricing">料金</a>
        <a href="#faq">FAQ</a>
      </nav>
      <a href="#apply" class="team-header-cta">チームプランを申し込む</a>
    </header>

    <section class="team-hero">
      <div class="team-hero-inner">
        <div class="team-hero-copy">
          <p class="team-kicker">Reki note Team</p>
          <h1>会話から、<br />業務の進捗が見える。</h1>
          <p class="team-lead">
            Google MeetやZoomに依存せず、会議・通話・1on1を要約。
            決定事項、関心ごと、アクションを組織で扱えるデータに変換します。
          </p>
          <div class="team-hero-actions">
            <a href="#apply" class="team-primary">チームプランを申し込む</a>
            <a href="#security" class="team-secondary">NDA・セキュリティについて</a>
          </div>
          <div class="team-trust-row" aria-label="導入対応">
            <span>NDA締結</span>
            <span>ローカル運用</span>
            <span>権限管理</span>
            <span>監査ログ</span>
          </div>
        </div>

        <div class="team-hero-product" aria-label="Reki note Team ダッシュボードのプレビュー">
          <div class="team-product-window dark">
            <div class="team-product-sidebar">
              <div class="team-product-brand">
                <img src="/logo.png" alt="" width="20" height="20" />
                <span>Reki note</span>
              </div>
              <span class="active">ダッシュボード</span>
              <span>会話タイムライン</span>
              <span>トピック</span>
              <span>アクション</span>
              <span>セキュリティ</span>
            </div>
            <div class="team-product-main">
              <div class="team-product-head">
                <div>
                  <p>Organization Intelligence</p>
                  <h2>ダッシュボード</h2>
                </div>
                <span>2026/05/01 - 05/31</span>
              </div>
              <div class="team-hero-metrics">
                <article><span>会話数</span><b>682</b><small>+12.4%</small></article>
                <article><span>完了率</span><b>65%</b><small>+8.7pt</small></article>
                <article><span>未解決</span><b>24</b><small>-6件</small></article>
              </div>
              <div class="team-hero-panel-grid">
                <article class="team-mini-bars">
                  <h3>部署別の会話量</h3>
                  {[92, 68, 44, 24].map((width) => <i style={`width:${width}%`} />)}
                </article>
                <article>
                  <h3>今週の論点</h3>
                  <ul>
                    <li>リリース計画</li>
                    <li>顧客オンボーディング</li>
                    <li>セキュリティ要件</li>
                  </ul>
                </article>
              </div>
              <div class="team-hero-table">
                {meetings.slice(0, 3).map((meeting) => (
                  <div>
                    <span>{meeting.app}</span>
                    <b>{meeting.title}</b>
                    <small>{meeting.actions}</small>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="team-assurance-strip" aria-label="企業導入の対応範囲">
        <div><b>エンタープライズセキュリティ</b><span>NDA締結・契約条件に対応</span></div>
        <div><b>データはお客様のもの</b><span>提出範囲を組織ポリシーで制御</span></div>
        <div><b>ビジネス要件に対応</b><span>SAML SSO / SCIM は個別相談</span></div>
      </div>
    </section>

    <section class="team-tools" aria-label="対応ツール">
      <p>主要な会議・通話・対面コミュニケーションに対応</p>
      <div>
        {supportedTools.map((tool) => <span>{tool}</span>)}
      </div>
    </section>

    <section class="team-flow" id="flow" aria-labelledby="flow-title">
      <div class="team-section-heading compact">
        <p>OPERATING MODEL</p>
        <h2 id="flow-title">会話が業務データになるまで</h2>
      </div>
      <div class="team-flow-band">
        {pipeline.map((item, index) => (
          <article>
            <span class="team-step-number">{String(index + 1).padStart(2, "0")}</span>
            <strong>{item.label}</strong>
            <h3>{item.title}</h3>
            <p>{item.body}</p>
          </article>
        ))}
      </div>
      <p class="team-flow-note">エンドツーエンドの暗号化、提出範囲の制御、監査ログを前提に、組織ごとの運用ポリシーに合わせて設計します。</p>
    </section>

    <section class="team-features" id="features" aria-labelledby="features-title">
      <div class="team-section-heading">
        <p>FEATURES</p>
        <h2 id="features-title">チーム導入で変わる3つのこと</h2>
      </div>
      <div class="team-feature-grid">
        {features.map((feature, index) => (
          <article>
            <span>{String(index + 1).padStart(2, "0")}</span>
            <h3>{feature.title}</h3>
            <p>{feature.body}</p>
            <ul>
              {feature.points.map((point) => <li>{point}</li>)}
            </ul>
          </article>
        ))}
      </div>
      <div class="team-mid-cta">
        <a href="#apply" class="team-primary">チームプランを申し込む</a>
        <a href="#product" class="team-secondary">機能の詳細を見る</a>
      </div>
    </section>

    <section class="team-product-section" id="product" aria-labelledby="product-title">
      <div class="team-section-heading dark">
        <p>PRODUCT</p>
        <h2 id="product-title">会話DXを進める機能</h2>
        <span>記録する、共有する、進捗を見る。社内会話を生成AIに渡せるデータへ変換します。</span>
      </div>
      <div class="team-function-stack">
        {functionBlocks.map((block, index) => (
          <article>
            <div>
              <span>0{index + 1}</span>
              <h3>{block.title}</h3>
              <p>{block.body}</p>
              <ul>{block.items.map((item) => <li>{item}</li>)}</ul>
            </div>
            <div class="team-function-visual" aria-hidden="true">
              <div class="team-mini-window">
                <b>{block.title}</b>
                <i />
                <i />
                <i />
                <small>{block.items[0]}</small>
              </div>
            </div>
          </article>
        ))}
      </div>
      <div class="team-dark-cta">
        <a href="#apply" class="team-primary">導入について相談する</a>
        <a href="#security" class="team-outline-light">セキュリティを見る</a>
      </div>
    </section>

    <section class="team-boundary" id="security" aria-labelledby="boundary-title">
      <div class="team-section-heading align-left">
        <p>SECURITY & COMPLIANCE</p>
        <h2 id="boundary-title">ローカル完結とクラウド機能の境界</h2>
        <span>秘密度の高い会話をPC内に残す運用と、組織で使う要約データをクラウドに提出する運用を分けて設計します。</span>
      </div>
      <div class="team-boundary-grid">
        <article>
          <p>ローカル完結モード</p>
          <h3>機密性の高い会話は、PC内で扱う。</h3>
          <ul>{localItems.map((item) => <li>{item}</li>)}</ul>
          <strong>このモードでは、音声・全文文字起こし・要約のいずれもクラウドに送信しない運用が可能です。</strong>
        </article>
        <div class="team-submit-column" aria-hidden="true">
          <span>ユーザー操作で提出</span>
          <b>要約・メタデータのみ</b>
        </div>
        <article>
          <p>チームクラウドモード</p>
          <h3>共有すべき情報だけを、組織で活用する。</h3>
          <ul>{cloudItems.map((item) => <li>{item}</li>)}</ul>
          <strong>クラウド機能はローカル完結ではありません。秘密保持契約と運用ポリシーで取り扱いを明確にします。</strong>
        </article>
      </div>
      <div class="team-compliance-row">
        <span>NDA締結対応</span>
        <span>DPA締結相談</span>
        <span>通信・保存の暗号化</span>
        <span>監査ログ保持</span>
        <span>IP制限相談</span>
        <span>事業継続計画に準拠</span>
      </div>
      <div class="team-mid-cta">
        <a href="#apply" class="team-primary">セキュリティ要件を相談する</a>
      </div>
    </section>

    <section class="team-usecases" aria-labelledby="usecases-title">
      <div class="team-section-heading">
        <p>USE CASES</p>
        <h2 id="usecases-title">最初に導入しやすい部門</h2>
      </div>
      <div class="team-usecase-grid">
        {useCases.map((useCase) => (
          <article>
            <span>{useCase.team}</span>
            <h3>{useCase.title}</h3>
            <p>{useCase.body}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="team-pricing" id="pricing" aria-labelledby="pricing-title">
      <div class="team-section-heading">
        <p>PRICING</p>
        <h2 id="pricing-title">チームの規模と要件に合わせて導入できます。</h2>
      </div>
      <div class="team-price-grid">
        <article>
          <span>Team</span>
          <h3><b>¥5,000</b> / 席 / 月</h3>
          <p>中小〜中堅企業向けの標準プラン。</p>
          <ul>
            <li>文字起こし・要約・検索</li>
            <li>会話の自動要約・共有</li>
            <li>プロジェクト、タグ、権限管理</li>
            <li>監査ログ・アクセス制御</li>
          </ul>
          <a href="#apply">チームプランを申し込む</a>
        </article>
        <article>
          <span>Enterprise</span>
          <h3><b>初期1,000万円〜</b></h3>
          <p>大企業・官公庁・厳格な要件を持つ組織向け。</p>
          <ul>
            <li>専用環境、個別要件、運用設計</li>
            <li>高度なセキュリティ・コンプライアンス対応</li>
            <li>データ保持ポリシーのカスタマイズ</li>
            <li>専任カスタマーサクセス・サポート</li>
          </ul>
          <a href="#apply" class="secondary">導入について相談する</a>
        </article>
      </div>
    </section>

    <section class="team-faq" id="faq" aria-labelledby="faq-title">
      <div class="team-section-heading dark">
        <p>FAQ</p>
        <h2 id="faq-title">よくある質問</h2>
      </div>
      <div class="team-faq-list">
        {faqs.map((faq) => (
          <details>
            <summary>{faq.q}</summary>
            <p>{faq.a}</p>
          </details>
        ))}
      </div>
      <div class="team-dark-cta">
        <a href="#apply" class="team-primary">チームプランを申し込む</a>
      </div>
    </section>

    <section class="team-application" aria-labelledby="apply-title">
      <div class="team-application-copy">
        <p class="team-kicker">APPLICATION</p>
        <h2 id="apply-title">チームプランを<br />申し込む</h2>
        <p>想定利用人数、NDAの希望、導入目的をお送りください。要件を確認し、導入方法と契約条件をご案内します。</p>
      </div>
      <TeamPlanApplicationForm client:load />
    </section>
  </main>
</BaseLayout>

<style>
  .team-page {
    --team-ink: #111218;
    --team-muted: #5b6472;
    --team-line: rgba(17, 18, 24, 0.12);
    --team-purple: #7c3aed;
    --team-purple-dark: #4c1d95;
    --team-purple-soft: #ede9fe;
    min-height: 100vh;
    background: #f7f7f8;
    color: var(--team-ink);
    word-break: normal;
    overflow-wrap: normal;
    line-break: strict;
  }

  .team-page *,
  .team-page *::before,
  .team-page *::after {
    box-sizing: border-box;
  }

  .team-page p,
  .team-page li,
  .team-page span,
  .team-page small,
  .team-page summary {
    overflow-wrap: break-word;
  }

  .team-header {
    position: sticky;
    top: 0;
    z-index: 50;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 28px;
    height: 64px;
    padding: 0 40px;
    border-bottom: 1px solid var(--team-line);
    background: rgba(247, 247, 248, 0.9);
    backdrop-filter: blur(16px);
  }

  .team-logo,
  .team-header nav,
  .team-header-cta,
  .team-primary,
  .team-secondary,
  .team-outline-light {
    display: inline-flex;
    align-items: center;
  }

  .team-logo {
    gap: 10px;
    color: var(--team-ink);
    font-weight: 800;
    text-decoration: none;
  }

  .team-logo img {
    border-radius: 7px;
  }

  .team-logo strong {
    padding: 2px 8px;
    border-radius: 6px;
    background: var(--team-purple);
    color: #fff;
    font-size: 12px;
  }

  .team-header nav {
    gap: 26px;
    font-size: 13px;
    font-weight: 700;
  }

  .team-header nav a,
  .team-secondary {
    color: #3f4652;
    text-decoration: none;
  }

  .team-header-cta,
  .team-primary {
    justify-content: center;
    border-radius: 8px;
    background: var(--team-purple);
    color: #fff;
    font-weight: 800;
    text-decoration: none;
    box-shadow: 0 16px 34px -22px rgba(124, 58, 237, 0.9);
  }

  .team-header-cta {
    padding: 10px 16px;
    font-size: 13px;
  }

  .team-primary,
  .team-secondary,
  .team-outline-light {
