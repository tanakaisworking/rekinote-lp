    border-radius: 5px;
    background: rgba(167, 139, 250, 0.18);
    color: #c4b5fd;
    font-size: 10px;
    font-weight: 800;
  }

  .team-hero-table b,
  .team-hero-table small {
    font-size: 11px;
  }

  .team-hero-table small {
    color: #34d399;
  }

  .team-assurance-strip {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
    max-width: 1240px;
    margin: 28px auto 0;
  }

  .team-assurance-strip div {
    min-height: 82px;
    padding: 18px;
    border: 1px solid rgba(22, 101, 52, 0.22);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.78);
  }

  .team-assurance-strip b,
  .team-assurance-strip span {
    display: block;
  }

  .team-assurance-strip b {
    color: #123824;
    font-size: 14px;
  }

  .team-assurance-strip span {
    margin-top: 8px;
    color: #536071;
    font-size: 12px;
  }

  .team-tools {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 22px;
    align-items: center;
    max-width: 1120px;
    margin: 0 auto;
    padding: 24px 24px 10px;
  }

  .team-tools p {
    margin: 0;
    color: #596273;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.04em;
  }

  .team-tools div {
    display: grid;
    grid-template-columns: repeat(6, minmax(0, 1fr));
    gap: 10px;
  }

  .team-tools span {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 42px;
    border: 1px solid rgba(17, 18, 24, 0.1);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.74);
    color: #293140;
    font-size: 12px;
    font-weight: 800;
    text-align: center;
  }

  .team-flow,
  .team-features,
  .team-boundary,
  .team-usecases,
  .team-pricing,
  .team-application {
    max-width: 1180px;
    margin: 0 auto;
    padding: 62px 24px;
  }

  .team-section-heading {
    max-width: 760px;
    margin: 0 auto 32px;
    text-align: center;
  }

  .team-section-heading.compact {
    margin-bottom: 24px;
  }

  .team-section-heading.align-left {
    margin-left: 0;
    text-align: left;
  }

  .team-section-heading.dark {
    color: #fff;
  }

  .team-section-heading h2,
  .team-boundary h2,
  .team-application h2 {
    margin: 10px 0 0;
    color: #0b0c11;
    font-size: clamp(30px, 4vw, 44px);
    letter-spacing: -0.025em;
    line-height: 1.35;
  }

  .team-section-heading.dark h2 {
    color: #fff;
  }

  .team-section-heading span,
  .team-application-copy p {
    display: block;
    margin-top: 14px;
    color: var(--team-muted);
    line-height: 1.9;
  }

  .team-section-heading.dark span {
    color: rgba(255, 255, 255, 0.72);
  }

  .team-flow {
    padding-top: 44px;
  }

  .team-flow-band {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    border: 1px solid var(--team-line);
    border-radius: 8px;
    background: #fff;
    overflow: hidden;
  }

  .team-flow-band article {
    position: relative;
    padding: 20px 18px;
    border-right: 1px solid var(--team-line);
  }

  .team-flow-band article:not(:last-child)::after {
    content: ">";
    position: absolute;
    top: 26px;
    right: -8px;
    z-index: 1;
    width: 16px;
    height: 16px;
    border-radius: 99px;
    background: #fff;
    color: var(--team-purple);
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 12px;
    font-weight: 800;
    line-height: 16px;
    text-align: center;
  }

  .team-flow-band article:last-child {
    border-right: 0;
  }

  .team-step-number {
    color: var(--team-purple);
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 11px;
    font-weight: 800;
  }

  .team-flow-band strong {
    display: block;
    margin-top: 10px;
    color: #111827;
    font-size: 18px;
  }

  .team-flow-band h3 {
    margin: 10px 0 0;
    color: #4b5563;
    font-size: 13px;
  }

  .team-flow-band p,
  .team-flow-note {
    color: var(--team-muted);
    font-size: 13px;
    line-height: 1.75;
  }

  .team-flow-note {
    margin: 14px 0 0;
    text-align: center;
  }

  .team-features {
    background: #fff;
    max-width: none;
    padding-left: max(24px, calc((100vw - 1180px) / 2 + 24px));
    padding-right: max(24px, calc((100vw - 1180px) / 2 + 24px));
  }

  .team-feature-grid,
  .team-function-stack,
  .team-boundary-grid,
  .team-compliance-row,
  .team-usecase-grid,
  .team-price-grid,
  .team-application {
    display: grid;
    gap: 16px;
  }

  .team-feature-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .team-feature-grid article,
  .team-boundary-grid article,
  .team-usecase-grid article,
  .team-price-grid article,
  :global(.team-form) {
    border: 1px solid var(--team-line);
    border-radius: 8px;
    background: #fff;
  }

  .team-feature-grid article,
  .team-usecase-grid article {
    padding: 24px;
  }

  .team-feature-grid article > span,
  .team-function-stack article > div:first-child > span,
  .team-price-grid article > span,
  .team-usecase-grid article > span {
    color: var(--team-purple);
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 12px;
    font-weight: 800;
  }

  .team-feature-grid h3,
  .team-usecase-grid h3,
  .team-boundary h3 {
    margin: 12px 0 0;
    color: #171923;
    font-size: 20px;
    line-height: 1.5;
  }

  .team-feature-grid p,
  .team-usecase-grid p {
    color: #4b5563;
    line-height: 1.8;
  }

  .team-feature-grid ul,
  .team-function-stack ul,
  .team-boundary-grid ul,
  .team-price-grid ul {
    padding: 0;
    margin: 18px 0 0;
    list-style: none;
  }

  .team-feature-grid li,
  .team-function-stack li,
  .team-boundary-grid li,
  .team-price-grid li {
    position: relative;
    padding-left: 18px;
    margin-top: 10px;
    color: #374151;
    line-height: 1.7;
  }

  .team-feature-grid li::before,
  .team-function-stack li::before,
  .team-boundary-grid li::before,
  .team-price-grid li::before {
    content: "";
    position: absolute;
    top: 0.78em;
    left: 0;
    width: 7px;
    height: 7px;
    border-radius: 99px;
    background: var(--team-purple);
  }

  .team-mid-cta {
    justify-content: center;
    margin-top: 28px;
  }

  .team-product-section,
  .team-faq {
    padding: 70px 24px;
    background: linear-gradient(180deg, #5a31a2 0%, #432477 100%);
    color: #fff;
  }

  .team-function-stack {
    max-width: 980px;
    margin: 0 auto;
  }

  .team-function-stack article {
    display: grid;
    grid-template-columns: 1fr 310px;
    gap: 28px;
    align-items: center;
    padding: 28px;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 8px;
    background: rgba(16, 12, 32, 0.58);
  }

  .team-function-stack h3 {
    margin: 10px 0 0;
    color: #fff;
    font-size: 24px;
  }

  .team-function-stack p {
    color: rgba(255, 255, 255, 0.78);
    line-height: 1.85;
  }

  .team-function-stack li {
    color: rgba(255, 255, 255, 0.82);
  }

  .team-mini-window {
    min-height: 190px;
    padding: 18px;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 8px;
    background: #0e111a;
  }

  .team-mini-window b,
  .team-mini-window small {
    display: block;
  }

  .team-mini-window i {
    display: block;
    height: 16px;
    margin-top: 14px;
    border-radius: 6px;
    background: linear-gradient(90deg, rgba(124, 58, 237, 0.82), rgba(167, 139, 250, 0.24));
  }

  .team-mini-window i:nth-of-type(2) {
    width: 78%;
  }

  .team-mini-window i:nth-of-type(3) {
    width: 52%;
  }

  .team-mini-window small {
    margin-top: 18px;
    color: #34d399;
    font-weight: 800;
  }

  .team-dark-cta {
    justify-content: center;
    margin-top: 30px;
  }

  .team-boundary {
    border-bottom: 1px solid var(--team-line);
  }

  .team-boundary-grid {
    grid-template-columns: minmax(0, 1fr) 160px minmax(0, 1fr);
    align-items: stretch;
    margin-top: 34px;
  }

  .team-boundary-grid article {
    padding: 28px;
  }

  .team-boundary-grid article p {
    margin: 0;
    color: var(--team-purple);
    font-size: 13px;
    font-weight: 800;
  }

  .team-boundary-grid strong {
    display: block;
    margin-top: 22px;
    padding: 14px;
    border-radius: 7px;
    background: #f3f4f6;
    color: #1f2937;
    font-size: 13px;
    line-height: 1.8;
  }

  .team-submit-column {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 10px;
    color: var(--team-muted);
    font-size: 12px;
    text-align: center;
  }

  .team-submit-column b {
    color: #111827;
  }

  .team-compliance-row {
    grid-template-columns: repeat(6, minmax(0, 1fr));
    margin-top: 16px;
  }

  .team-compliance-row span {
    justify-content: center;
    min-height: 54px;
    text-align: center;
  }

  .team-usecases {
    background: #f0f1f5;
    max-width: none;
    padding-left: max(24px, calc((100vw - 1180px) / 2 + 24px));
    padding-right: max(24px, calc((100vw - 1180px) / 2 + 24px));
  }

  .team-usecase-grid {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .team-usecase-grid article {
    min-height: 230px;
  }

  .team-pricing {
    background: #fff;
    max-width: none;
    padding-left: max(24px, calc((100vw - 1180px) / 2 + 24px));
    padding-right: max(24px, calc((100vw - 1180px) / 2 + 24px));
  }

  .team-price-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .team-price-grid article {
    padding: 32px;
  }

  .team-price-grid h3 {
    margin: 12px 0 0;
    font-size: 20px;
  }

  .team-price-grid h3 b {
    font-size: clamp(34px, 4vw, 52px);
    letter-spacing: -0.03em;
  }

  .team-price-grid p {
    color: var(--team-muted);
  }

  .team-price-grid a {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    margin-top: 26px;
    border-radius: 8px;
    background: var(--team-purple);
    color: #fff;
    font-weight: 800;
    text-decoration: none;
  }

  .team-price-grid a.secondary {
    border: 1px solid var(--team-line);
    background: #fff;
    color: #111827;
  }

  .team-faq-list {
    max-width: 820px;
    margin: 0 auto;
  }

  .team-faq-list details {
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.96);
    color: #111827;
  }

  .team-faq-list details + details {
    margin-top: 10px;
  }

  .team-faq-list summary {
    cursor: pointer;
    padding: 16px 18px;
    font-weight: 800;
  }

  .team-faq-list p {
    margin: 0;
    padding: 0 18px 18px;
    color: #4b5563;
    line-height: 1.8;
  }

  .team-application {
    grid-template-columns: 0.78fr 1.22fr;
    align-items: start;
    padding-bottom: 96px;
  }

  :global(.team-form) {
    padding: 28px;
  }

  :global(.team-form-grid) {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
  }

  :global(.team-form label) {
    display: block;
  }

  :global(.team-form span) {
    display: block;
    color: #374151;
    font-size: 13px;
    font-weight: 800;
  }

  :global(.team-form input),
  :global(.team-form select),
  :global(.team-form textarea) {
    width: 100%;
    margin-top: 8px;
    border: 1px solid rgba(17, 18, 24, 0.16);
    border-radius: 8px;
    background: #fff;
    color: #111827;
    font: inherit;
    font-size: 15px;
    outline: none;
    transition: border-color 160ms ease, box-shadow 160ms ease;
  }

  :global(.team-form input),
  :global(.team-form select) {
    height: 48px;
    padding: 0 13px;
  }

  :global(.team-form textarea) {
    resize: vertical;
    padding: 12px 13px;
    line-height: 1.7;
  }

  :global(.team-form input:focus),
  :global(.team-form select:focus),
  :global(.team-form textarea:focus) {
    border-color: rgba(124, 58, 237, 0.62);
    box-shadow: 0 0 0 3px rgba(124, 58, 237, 0.12);
  }

  :global(.team-form-message) {
    margin-top: 16px;
  }

  :global(.team-form-honeypot) {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    opacity: 0;
  }

  :global(.team-form-actions) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    margin-top: 22px;
  }

  :global(.team-form-actions p) {
    margin: 0;
    color: var(--team-muted);
    font-size: 13px;
    line-height: 1.8;
  }

  :global(.team-form-actions button) {
    flex: 0 0 auto;
    min-height: 48px;
    border: 0;
    border-radius: 8px;
    background: var(--team-purple);
    color: #fff;
    cursor: pointer;
    font: inherit;
    font-weight: 800;
    padding: 0 20px;
  }

  :global(.team-form-actions button:disabled) {
    cursor: wait;
    opacity: 0.7;
  }

  :global(.team-form-success),
  :global(.team-form-error) {
    margin-top: 16px;
    border-radius: 8px;
    padding: 13px 14px;
    font-size: 13px;
    font-weight: 700;
  }

  :global(.team-form-success) {
    background: rgba(22, 163, 74, 0.1);
    color: #166534;
  }

  :global(.team-form-error) {
    background: rgba(220, 38, 38, 0.1);
    color: #991b1b;
  }

  @media (max-width: 1080px) {
    .team-header {
      padding: 0 20px;
    }

    .team-header nav {
      display: none;
    }

    .team-hero-inner,
    .team-application,
    .team-function-stack article {
      grid-template-columns: 1fr;
    }

    .team-hero-product {
      min-width: 0;
    }

    .team-assurance-strip,
    .team-tools,
    .team-feature-grid,
    .team-boundary-grid,
