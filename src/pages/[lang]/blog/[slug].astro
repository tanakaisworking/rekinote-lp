---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { locales, type Locale } from "../../../i18n/getDictionary";
import { getAllBlogsRaw, localizeBlog } from "../../../lib/microcms";

export async function getStaticPaths() {
  const rawBlogs = await getAllBlogsRaw();
  const paths = [];
  for (const raw of rawBlogs) {
    for (const lang of locales) {
      const blogLang = (lang === "ko" || lang === "zh-tw") ? "en" : lang;
      const blog = localizeBlog(raw, blogLang);
      if (blog) {
        paths.push({ params: { lang, slug: raw.id }, props: { blog } });
      }
    }
  }
  return paths;
}

const lang = Astro.params.lang as Locale;
const { blog } = Astro.props;

const publishedDate = new Date(blog.publishedAt!).toLocaleDateString(lang, {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const ogImage = blog.eyecatch?.url ? `${blog.eyecatch.url}?w=1200&h=630&fit=crop` : undefined;

const jsonLdArticle = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: blog.title,
  datePublished: blog.publishedAt,
  dateModified: blog.updatedAt,
  author: {
    "@type": "Organization",
    name: "ヒバチ株式会社",
    url: "https://hibachi-inc.jp",
  },
  publisher: {
    "@type": "Organization",
    name: "ヒバチ株式会社",
    logo: { "@type": "ImageObject", url: "https://rekinote.app/logo-transparent.png" },
  },
  ...(blog.eyecatch?.url && { image: blog.eyecatch.url }),
  ...(blog.description && { description: blog.description }),
};
---

<BaseLayout
  title={`${blog.title} — Reki note`}
  description={blog.description || blog.title}
  ogImage={ogImage}
  lang={lang}
  canonical={`https://rekinote.app/${lang}/blog/${blog.id}/`}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLdArticle)} />
  </Fragment>

  <div class="min-h-screen bg-[#0c0c10] text-[#ececef]">
    <header class="border-b border-line">
      <div class="container-x px-6 py-5 flex items-center gap-2.5">
        <a href={`/${lang}/lp/business/`} class="flex items-center gap-2.5 hover:opacity-80 transition-opacity">
          <img src="/logo.png" alt="" width="24" height="24" class="rounded-md" />
          <span class="font-semibold tracking-tight">Reki note</span>
        </a>
      </div>
    </header>

    <main class="container-x px-6 py-14 max-w-2xl">
      <a href={`/${lang}/blog/`} class="inline-flex items-center gap-1.5 text-sm text-[#a0a0ad] hover:text-[#a78bfa] transition-colors mb-8">
        <svg viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4"><path fill-rule="evenodd" d="M17 10a.75.75 0 01-.75.75H5.612l4.158 3.96a.75.75 0 11-1.04 1.08l-5.5-5.25a.75.75 0 010-1.08l5.5-5.25a.75.75 0 111.04 1.08L5.612 9.25H16.25A.75.75 0 0117 10z" clip-rule="evenodd" /></svg>
        {lang === "ja" ? "ブログ一覧" : lang === "ko" ? "블로그 목록" : lang === "zh-tw" ? "返回部落格" : "Back to blog"}
      </a>

      <article>
        <div class="flex items-center gap-3 text-xs text-[#a0a0ad]">
          <time datetime={blog.publishedAt}>{publishedDate}</time>
          {blog.category && (
            <span class="px-2 py-0.5 rounded-full bg-[#a78bfa]/10 text-[#a78bfa] text-[11px] font-medium">
              {blog.category.name}
            </span>
          )}
        </div>

        <h1 class="mt-4 text-2xl md:text-3xl font-bold tracking-tight leading-snug">{blog.title}</h1>

        {blog.eyecatch && (
          <img
            src={`${blog.eyecatch.url}?w=800`}
            alt=""
            width={blog.eyecatch.width}
            height={blog.eyecatch.height}
            class="mt-8 rounded-xl w-full"
            loading="eager"
          />
        )}

        <div class="mt-10 prose-blog" set:html={blog.body} />
      </article>
    </main>

    <footer class="border-t border-line">
      <div class="container-x px-6 py-6 dim text-xs">
        <span>&copy; 2026 HIBACHI inc.</span>
      </div>
    </footer>
  </div>
</BaseLayout>
