---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { locales, type Locale } from "../../../i18n/getDictionary";
import { getBlogs } from "../../../lib/microcms";

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Locale;
const blogLang = (lang === "ko" || lang === "zh-tw") ? "en" : lang;
const { contents: blogs, totalCount } = await getBlogs(blogLang, 20);

const meta: Record<string, { title: string; description: string }> = {
  ja: { title: "ブログ — Reki note", description: "Reki noteの最新情報、使い方のヒント、開発の裏側をお届けします。" },
  en: { title: "Blog — Reki note", description: "Latest updates, tips, and behind-the-scenes from Reki note." },
  ko: { title: "블로그 — Reki note", description: "Reki note의 최신 소식, 사용 팁, 개발 비하인드를 전해드려요." },
  "zh-tw": { title: "部落格 — Reki note", description: "Reki note 的最新消息、使用技巧與開發幕後。" },
};
const { title, description } = meta[lang] ?? meta.ja;
---

<BaseLayout title={title} description={description} lang={lang} canonical={`https://rekinote.app/${lang}/blog/`}>
  <div class="min-h-screen bg-[#0c0c10] text-[#ececef]">
    <header class="border-b border-line">
      <div class="container-x px-6 py-5 flex items-center gap-2.5">
        <a href={`/${lang}/lp/business/`} class="flex items-center gap-2.5 hover:opacity-80 transition-opacity">
          <img src="/logo.png" alt="" width="24" height="24" class="rounded-md" />
          <span class="font-semibold tracking-tight">Reki note</span>
        </a>
      </div>
    </header>

    <main class="container-x px-6 py-14 max-w-3xl">
      <h1 class="text-3xl font-bold tracking-tight">{lang === "ja" ? "ブログ" : lang === "ko" ? "블로그" : lang === "zh-tw" ? "部落格" : "Blog"}</h1>
      <p class="mt-3 text-sm text-[#a0a0ad]">{totalCount} {lang === "ja" ? "件の記事" : lang === "ko" ? "개의 글" : lang === "zh-tw" ? "篇文章" : "articles"}</p>

      <div class="mt-10 space-y-8">
        {blogs.map((blog) => (
          <a href={`/${lang}/blog/${blog.id}/`} class="block group">
            <article class="flex gap-6 items-start">
              {blog.eyecatch && (
                <img
                  src={`${blog.eyecatch.url}?w=240&h=160&fit=crop`}
                  alt=""
                  width="240"
                  height="160"
                  class="rounded-lg object-cover shrink-0 hidden sm:block"
                  loading="lazy"
                />
              )}
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-3 text-xs text-[#a0a0ad]">
                  <time datetime={blog.publishedAt}>
                    {new Date(blog.publishedAt!).toLocaleDateString(lang, { year: "numeric", month: "long", day: "numeric" })}
                  </time>
                  {blog.category && (
                    <span class="px-2 py-0.5 rounded-full bg-[#a78bfa]/10 text-[#a78bfa] text-[11px] font-medium">
                      {blog.category.name}
                    </span>
                  )}
                </div>
                <h2 class="mt-2 text-lg font-semibold tracking-tight group-hover:text-[#a78bfa] transition-colors leading-snug">
                  {blog.title}
                </h2>
                {blog.description && (
                  <p class="mt-2 text-sm text-[#a0a0ad] line-clamp-2 leading-relaxed">{blog.description}</p>
                )}
              </div>
            </article>
          </a>
        ))}
      </div>

      {blogs.length === 0 && (
        <p class="mt-10 text-[#a0a0ad]">{lang === "ja" ? "まだ記事がありません。" : lang === "ko" ? "아직 글이 없어요." : lang === "zh-tw" ? "目前還沒有文章。" : "No articles yet."}</p>
      )}
    </main>

    <footer class="border-t border-line">
      <div class="container-x px-6 py-6 dim text-xs">
        <span>&copy; 2026 HIBACHI inc.</span>
      </div>
    </footer>
  </div>
</BaseLayout>
