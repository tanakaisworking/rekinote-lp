        "우선 지원",
      ],
    },
  ] as Plan[],
  faq: [
    { q: "무료 시간을 다 쓰면 어떻게 되나요?", a: "음성 인식이 일시 중지돼요. 다음 달에 3시간이 자동 복구되거나, 언제든 Pro로 업그레이드할 수 있어요." },
    { q: "어떤 결제 수단을 지원하나요?", a: "Visa, Mastercard, JCB, American Express를 지원해요." },
    { q: "언제든 해지할 수 있나요?", a: "네. 앱 설정에서 언제든 해지 가능해요. 해지 후에도 결제 기간 종료일까지 이용할 수 있어요." },
    { q: "연간 요금제가 있나요?", a: "현재는 월간 요금제만 있어요. 연간 요금제는 추가 예정이에요." },
  ],
};

const zhTw = {
  eyebrow: "PRICING",
  title: "簡單的價格方案",
  subtitle: "免費開始。需要更多功能時再升級。",
  plans: [
    {
      name: "Free",
      price: "$0",
      period: "",
      desc: "註冊後馬上就能使用。",
