        "註冊時獲得 20 小時語音轉文字",
        "每月自動恢復 3 小時",
        "AI 聊天（免費額度內）",
        "支援所有會議工具",
        "本機儲存，隱私優先",
        "Markdown / Obsidian 匯出",
      ],
    },
    {
      name: "Pro",
      price: "$9.99",
      period: "/月",
      desc: "每天都有會議的商務使用者適用。",
      features: [
        "語音轉文字 30 小時/月",
        "AI 聊天 50 小時/月",
        "支援所有會議工具",
        "本機儲存，隱私優先",
        "Markdown / Obsidian 匯出",
        "優先客服",
      ],
      highlight: true,
    },
    {
      name: "Pro Full-time",
      price: "$34.99",
      period: "/月",
      desc: "整天都在開會的重度使用者適用。",
      features: [
        "語音轉文字 160 小時/月",
        "AI 聊天 100 次/月",
        "支援所有會議工具",
        "本機儲存，隱私優先",
        "Markdown / Obsidian 匯出",
        "優先客服",
      ],
    },
  ] as Plan[],
  faq: [
    { q: "免費時數用完後會怎樣？", a: "語音轉文字會暫停。下個月會自動恢復 3 小時，或者你可以隨時升級至 Pro。" },
    { q: "支援哪些付款方式？", a: "支援 Visa、Mastercard、JCB 及 American Express。" },
    { q: "可以隨時取消嗎？", a: "可以。隨時在應用程式設定中取消。取消後仍可使用至計費期結束。" },
    { q: "有年繳方案嗎？", a: "目前只有月繳方案。年繳方案即將推出。" },
  ],
};

const allPricing: Record<string, typeof ja> = { ja, en, ko, "zh-tw": zhTw };
const t = allPricing[lang] ?? en;
---

<BaseLayout title={title} description={description} lang={lang} canonical={`https://rekinote.app/${lang}/pricing/`}>
  <div class="min-h-screen bg-[#0c0c10] text-[#ececef]">
    <header class="border-b border-line">
      <div class="container-x px-6 py-5 flex items-center gap-2.5">
        <a
          href={`/${lang}/lp/business/`}
          class="flex items-center gap-2.5 hover:opacity-80 transition-opacity"
        >
          <img src="/logo.png" alt="" width="24" height="24" class="rounded-md" />
          <span class="font-semibold tracking-tight">Reki note</span>
        </a>
      </div>
    </header>

    <main class="container-x px-6 py-20 max-w-5xl">
      <div class="text-center">
        <p class="eyebrow">{t.eyebrow}</p>
        <h1 class="mt-4 text-3xl font-bold tracking-tight sm:text-4xl">
          {t.title}
        </h1>
        <p class="mt-4 text-base text-[#b6b6c2]">{t.subtitle}</p>
      </div>

      <div class="mt-14 grid gap-6 md:grid-cols-3">
        {t.plans.map((plan) => (
          <div
            class={`rounded-2xl p-8 ${
              plan.highlight
                ? "bg-gradient-to-b from-[#2a1f5e]/60 to-[#1a1a22] border-2 border-[#7c3aed]/40 shadow-[0_0_40px_-12px_rgba(139,92,246,0.3)]"
                : "bg-[#16161e] border border-line"
            }`}
          >
            <div class="flex items-center gap-3">
              <h2 class="text-xl font-semibold">{plan.name}</h2>
              {plan.highlight && (
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-semibold tracking-wide uppercase bg-[#7c3aed]/20 text-[#a78bfa] border border-[#7c3aed]/30">
                  Popular
                </span>
              )}
            </div>
            <div class="mt-4 flex items-baseline gap-1">
              <span class="text-4xl font-bold tracking-tight">{plan.price}</span>
              {plan.period && (
                <span class="text-base text-[#8e8e98]">{plan.period}</span>
              )}
            </div>
            <p class="mt-3 text-sm text-[#b6b6c2]">{plan.desc}</p>

            <ul class="mt-8 space-y-3">
              {plan.features.map((f) => (
                <li class="flex items-start gap-2.5 text-sm">
                  <svg viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 shrink-0 text-emerald-400 mt-0.5">
                    <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z" clip-rule="evenodd" />
                  </svg>
                  <span>{f}</span>
                </li>
              ))}
            </ul>

          </div>
        ))}
      </div>

      <section class="mt-24 max-w-2xl mx-auto">
        <h2 class="text-xl font-semibold tracking-tight text-center">
          {lang === "ja" ? "よくある質問" : lang === "ko" ? "자주 묻는 질문" : lang === "zh-tw" ? "常見問題" : "FAQ"}
        </h2>
        <dl class="mt-10 divide-y divide-line">
          {t.faq.map((item) => (
            <div class="py-5">
              <dt class="text-sm font-medium">{item.q}</dt>
              <dd class="mt-2 text-sm text-[#b6b6c2] leading-relaxed">
                {item.a}
              </dd>
            </div>
          ))}
        </dl>
      </section>
    </main>

    <footer class="border-t border-line">
      <div class="container-x px-6 py-6 dim text-xs flex flex-wrap gap-x-6 gap-y-2 items-center justify-between">
        <span>© 2026 HIBACHI inc.</span>
        <a
          href={`/${lang}/legal/tokushoho/`}
          class="hover:text-[#ececef] transition-colors"
        >
          {lang === "ja" ? "特定商取引法に基づく表記" : "Legal"}
        </a>
      </div>
    </footer>
  </div>
</BaseLayout>
