      q: "Is there an annual plan?",
      a: "Not yet — monthly only for now. An annual plan is coming soon.",
    },
  ],
};

const ko = {
  eyebrow: "PRICING",
  title: "심플한 요금 체계",
  subtitle: "무료로 시작하세요. 필요할 때 업그레이드.",
  plans: [
    {
      name: "Free",
      price: "$0",
      period: "",
      desc: "가입하면 바로 사용할 수 있어요.",
      features: [
        "가입 시 20시간 음성 인식 제공",
        "매월 3시간 자동 복구",
        "AI 채팅 (무료 할당량 내)",
        "모든 회의 도구 지원",
        "로컬 저장, 프라이버시 우선",
        "Markdown / Obsidian 내보내기",
      ],
    },
    {
      name: "Pro",
      price: "$9.99",
      period: "/월",
      desc: "매일 회의가 있는 비즈니스 사용자를 위해.",
      features: [
        "음성 인식 30시간/월",
        "AI 채팅 50시간/월",
        "모든 회의 도구 지원",
        "로컬 저장, 프라이버시 우선",
        "Markdown / Obsidian 내보내기",
        "우선 지원",
      ],
      highlight: true,
    },
    {
      name: "Pro Full-time",
      price: "$34.99",
      period: "/월",
      desc: "하루 종일 회의가 이어지는 헤비 유저를 위해.",
      features: [
        "음성 인식 160시간/월",
        "AI 채팅 100회/월",
        "모든 회의 도구 지원",
        "로컬 저장, 프라이버시 우선",
