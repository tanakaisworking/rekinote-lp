      body: "從行事曆擷取你正在做的事，錄下語音。之後想交給 AI 處理時，直接丟過去就好。",
      steps: [
        { label: "Calendar", desc: "匯入行程，建立脈絡" },
        { label: "Record", desc: "會議、課堂、對話的語音，原樣保留" },
        { label: "Structure", desc: "把語音和行事曆串在一起，結構化" },
        { label: "AI Ready", desc: "以 AI 可用的格式，一直留在手邊" },
      ],
    },
    layer: {
      eyebrow: "Architecture",
      title: "Reki 所在的位置，就在這裡。",
      layers: [
        { label: "Hardware", sub: "麥克風、喇叭、鏡頭" },
        { label: "OS", sub: "macOS / Windows" },
        { label: "Reki note", sub: "將語音與行事曆結構化並記錄" },
        { label: "LLM / AI", sub: "語音辨識、摘要、問答" },
        { label: "Apps", sub: "文件、聊天、CRM、會議紀錄" },
      ],
