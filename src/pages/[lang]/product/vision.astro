      winSub: "Windows 10 以上",
      btnDefault: "免費下載 Mac 版",
      btnWin: "免費下載 Windows 版",
      preview: {
        ariaLabel: "Reki note 首頁畫面預覽",
        recordTitle: "開始錄音",
        recordSubtitle: "記錄下一場會議",
        importAudio: "匯入錄音",
        todaySchedule: "今天的行程",
        schedule: [
          { time: "10:00", title: "週會", status: "即將開始" },
