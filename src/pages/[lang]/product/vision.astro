        sessions: [
          { title: "週會 / 產品團隊", time: "今天 10:00〜10:45", app: "Google Meet", attendees: "6", preview: "發布日定為 5/15。QA 在下週三前完成。設計審查已結束。" },
          { title: "客戶會議 / A 公司", time: "5/7 13:00〜14:00", app: "Zoom", attendees: "4", preview: "補充需求訪談。確認 API 串接範圍。下次提出報價。" },
          { title: "1on1 / 陳志明", time: "5/6 16:00〜16:30", app: "面對面", attendees: "2", preview: "討論職涯方向。下個月的目標設定在下次前準備好。" },
        ],
        attendeesUnit: "人",
        aiLink: "開啟紀錄",
        aiQuestion: "這週客戶會議決定的待辦事項有哪些？",
      },
    },
    footer: {
      tagline: "Reki note · 把你的紀錄，變成價值。",
      company: "營運公司",
      switchHeading: "頁面",
      businessLabel: "商務",
      businessDesc: "會議、業務洽談、1on1、面對面會議的紀錄一次搞定。",
      studentLabel: "學生",
      studentDesc: "課堂、語音辨識、考前複習變得輕鬆。",
      developerLabel: "開發者",
      developerDesc: "API 串接、語音處理、外掛開發技術資訊。",
      visionLabel: "產品願景",
      visionDesc: "Reki 名字的由來與所追求的世界。",
      otherLabel: "首頁",
